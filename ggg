<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AuditLab · 大数据审计代码参考</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<link id="hljs-theme" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/python.min.js"></script>

<style>
  :root[data-theme="light"] {
    --bg: #fafafa;
    --surface: #ffffff;
    --hover: #f4f4f6;
    --border: #e7e7ec;
    --border-strong: #d4d4dc;
    --text: #1a1a1f;
    --text-mute: #6b6b78;
    --text-dim: #a0a0ac;
    --accent: #4f46e5;
    --accent-soft: #eef2ff;
    --code-bg: #fafafa;
    --shadow: 0 1px 3px rgba(0,0,0,0.04);
    --shadow-lg: 0 10px 30px rgba(0,0,0,0.08);
  }
  :root[data-theme="dark"] {
    --bg: #0d0d12;
    --surface: #16161d;
    --hover: #1d1d25;
    --border: #25252e;
    --border-strong: #34343f;
    --text: #e8e8ee;
    --text-mute: #9a9aa8;
    --text-dim: #5e5e6c;
    --accent: #818cf8;
    --accent-soft: rgba(129, 140, 248, 0.12);
    --code-bg: #0a0a10;
    --shadow: 0 1px 3px rgba(0,0,0,0.3);
    --shadow-lg: 0 10px 30px rgba(0,0,0,0.5);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    font-size: 14px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  /* ============ 顶部栏 ============ */
  .header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    width: 26px; height: 26px;
    border-radius: 7px;
    background: var(--accent);
    color: white;
    display: grid; place-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
  }
  .brand-sub {
    color: var(--text-dim);
    font-weight: 400;
    margin-left: 6px;
  }

  .header-actions { display: flex; gap: 8px; align-items: center; }
  .view-switch {
    display: flex;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2px;
  }
  .view-btn {
    padding: 6px 10px;
    border: none;
    background: transparent;
    color: var(--text-mute);
    cursor: pointer;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: inherit;
    font-size: 12.5px;
    transition: all 0.15s ease;
  }
  .view-btn:hover { color: var(--text); }
  .view-btn.active {
    background: var(--surface);
    color: var(--text);
    box-shadow: var(--shadow);
  }
  .view-btn svg { width: 14px; height: 14px; }

  .icon-btn {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-mute);
    cursor: pointer;
    display: grid; place-items: center;
    transition: all 0.15s ease;
  }
  .icon-btn:hover {
    background: var(--hover);
    color: var(--text);
  }
  .icon-btn svg { width: 16px; height: 16px; }

  /* ============ 主容器 ============ */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px;
  }

  /* ============ 面包屑 ============ */
  .crumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-mute);
    margin-bottom: 18px;
    font-family: 'JetBrains Mono', monospace;
  }
  .crumb {
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 5px;
    transition: all 0.15s ease;
  }
  .crumb:hover {
    background: var(--hover);
    color: var(--text);
  }
  .crumb.current {
    color: var(--text);
    cursor: default;
  }
  .crumb.current:hover { background: transparent; }
  .crumb-sep { color: var(--text-dim); }

  /* ============ 表头 ============ */
  .list-header {
    display: grid;
    grid-template-columns: 1fr 130px 100px 110px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    font-weight: 600;
  }
  .list-header .col-right { text-align: right; }

  /* ============ 列表项 ============ */
  .list {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 130px 100px 110px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.12s ease;
    align-items: center;
  }
  .row:last-child { border-bottom: none; }
  .row:hover { background: var(--hover); }
  .row .col-right { text-align: right; color: var(--text-mute); font-size: 13px; }

  .row-name {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .row-icon {
    width: 28px; height: 28px;
    border-radius: 6px;
    display: grid; place-items: center;
    flex-shrink: 0;
  }
  .row-icon.folder {
    background: var(--accent-soft);
    color: var(--accent);
  }
  .row-icon.file {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-mute);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
  }
  .row-text { min-width: 0; }
  .row-title {
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row-desc {
    font-size: 12.5px;
    color: var(--text-mute);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-mute);
  }

  /* ============ 网格视图 ============ */
  .grid-view {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
  }
  .grid-item {
    padding: 18px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: center;
    box-shadow: var(--shadow);
  }
  .grid-item:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }
  .grid-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    margin: 0 auto 10px;
    display: grid; place-items: center;
  }
  .grid-item.file .grid-icon {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-mute);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
  }
  .grid-title {
    font-weight: 500;
    font-size: 13.5px;
    line-height: 1.3;
    margin-bottom: 4px;
    word-break: break-word;
  }
  .grid-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-mute);
  }

  /* ============ 代码详情页 ============ */
  .detail {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .detail-head {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }
  .detail-info { min-width: 0; flex: 1; }
  .detail-title {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .detail-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .tag {
    padding: 3px 8px;
    border-radius: 5px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 11.5px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
  }
  .copy-btn {
    padding: 7px 13px;
    border-radius: 7px;
    background: var(--text);
    color: var(--surface);
    border: none;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 7px;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .copy-btn:hover { opacity: 0.85; }
  .copy-btn.copied { background: #16a34a; color: white; }
  .copy-btn svg { width: 13px; height: 13px; }

  .detail-code {
    background: var(--code-bg);
  }
  .detail-code pre {
    margin: 0;
    padding: 22px 24px;
    overflow: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
  }
  .detail-code pre::-webkit-scrollbar { height: 8px; width: 8px; }
  .detail-code pre::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }
  .detail-code pre::-webkit-scrollbar-track { background: transparent; }

  /* ============ 空状态 ============ */
  .empty {
    padding: 60px 20px;
    text-align: center;
    color: var(--text-mute);
  }

  /* ============ Toast ============ */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: var(--text);
    color: var(--surface);
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transition: all 0.25s ease;
    pointer-events: none;
    z-index: 100;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ============ 动画 ============ */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .view, .detail { animation: fadeIn 0.2s ease both; }

  /* ============ 响应式 ============ */
  @media (max-width: 700px) {
    .header { padding: 14px 18px; }
    .container { padding: 20px 18px; }
    .list-header, .row {
      grid-template-columns: 1fr 80px;
    }
    .col-hide { display: none; }
    .detail-head { flex-direction: column; }
  }
</style>
</head>
<body>

<header class="header">
  <div class="brand">
    <div class="brand-mark">A/</div>
    <span>AuditLab</span>
    <span class="brand-sub">大数据审计</span>
  </div>
  <div class="header-actions">
    <div class="view-switch">
      <button class="view-btn active" id="viewList">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        列表
      </button>
      <button class="view-btn" id="viewGrid">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
