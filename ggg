  /* ============ 状态 ============ */
  let currentView = 'list';        // 'list' | 'grid'
  let currentLab = null;            // 当前 lab id，null 表示在根目录
  let currentTask = null;           // 当前 task 索引，null 表示未进入详情

  /* ============ 工具函数 ============ */
  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
  }

  function fileIcon() {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
    </svg>`;
  }
  function folderIcon() {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
    </svg>`;
  }

  /* ============ 渲染 ============ */
  function render() {
    renderCrumbs();
    const content = document.getElementById('content');

    if (currentTask !== null) {
      content.innerHTML = renderDetail();
      hljs.highlightElement(content.querySelector('pre code'));
      bindDetailEvents();
      return;
    }

    if (currentLab === null) {
      // 根目录：列出所有 Lab
      const items = labs.map(lab => ({
        type: 'folder',
        title: `${lab.no} · ${lab.title}`,
        desc: lab.desc,
        meta: `${lab.tasks.length} 题`,
        size: `${lab.tasks.length} items`,
        onClick: () => { currentLab = lab.id; render(); }
      }));
      content.innerHTML = renderView(items);
    } else {
      // Lab 内部：列出所有 Task
      const lab = labs.find(l => l.id === currentLab);
      const items = lab.tasks.map((t, idx) => ({
        type: 'file',
        title: `${t.no} · ${t.title}`,
        desc: t.tags.map(tag => '#' + tag).join('  '),
        meta: `${t.code.split('\n').length} 行`,
        size: `${t.code.split('\n').length} lines`,
        ext: 'PY',
        onClick: () => { currentTask = idx; render(); }
      }));
      content.innerHTML = renderView(items);
    }

    bindRowEvents();
  }

  function renderCrumbs() {
    const crumbs = document.getElementById('crumbs');
    let html = `<span class="crumb ${currentLab === null ? 'current' : ''}" data-jump="root">~ / AuditLab</span>`;

    if (currentLab !== null) {
      const lab = labs.find(l => l.id === currentLab);
      html += `<span class="crumb-sep">/</span>`;
      html += `<span class="crumb ${currentTask === null ? 'current' : ''}" data-jump="lab">${lab.no}</span>`;

      if (currentTask !== null) {
        html += `<span class="crumb-sep">/</span>`;
        html += `<span class="crumb current">${escapeHtml(lab.tasks[currentTask].no)}</span>`;
      }
    }
    crumbs.innerHTML = html;

    crumbs.querySelectorAll('.crumb').forEach(c => {
      c.addEventListener('click', () => {
        const jump = c.dataset.jump;
        if (jump === 'root') { currentLab = null; currentTask = null; render(); }
        else if (jump === 'lab') { currentTask = null; render(); }
      });
    });
  }

  function renderView(items) {
    if (currentView === 'list') {
      return `
        <div class="view">
          <div class="list-header">
            <div>名称</div>
            <div class="col-hide">标签 / 描述</div>
            <div class="col-hide">类型</div>
            <div class="col-right">大小</div>
          </div>
          <div class="list">
            ${items.map((it, i) => `
              <div class="row" data-idx="${i}">
                <div class="row-name">
                  <div class="row-icon ${it.type === 'folder' ? 'folder' : 'file'}">
                    ${it.type === 'folder' ? folderIcon() : (it.ext || fileIcon())}
                  </div>
                  <div class="row-text">
                    <div class="row-title">${escapeHtml(it.title)}</div>
                    <div class="row-desc">${escapeHtml(it.desc)}</div>
                  </div>
                </div>
                <div class="col-hide row-meta">${escapeHtml(it.desc)}</div>
                <div class="col-hide row-meta">${it.type === 'folder' ? '文件夹' : 'Python'}</div>
                <div class="col-right">${escapeHtml(it.size)}</div>
              </div>
            `).join('')}
          </div>
        </div>
      `;
    } else {
      return `
        <div class="view grid-view">
          ${items.map((it, i) => `
            <div class="grid-item ${it.type}" data-idx="${i}">
              <div class="grid-icon">
                ${it.type === 'folder' ? folderIcon() : (it.ext || fileIcon())}
              </div>
              <div class="grid-title">${escapeHtml(it.title)}</div>
              <div class="grid-meta">${escapeHtml(it.meta)}</div>
            </div>
          `).join('')}
        </div>
      `;
    }
  }

  function bindRowEvents() {
    document.querySelectorAll('.row, .grid-item').forEach(el => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.dataset.idx);
        if (currentLab === null) {
          currentLab = labs[idx].id;
        } else {
          currentTask = idx;
        }
        render();
      });
    });
  }

  function renderDetail() {
    const lab = labs.find(l => l.id === currentLab);
    const t = lab.tasks[currentTask];
    return `
      <div class="detail">
        <div class="detail-head">
          <div class="detail-info">
            <div class="detail-title">${escapeHtml(t.title)}</div>
            <div class="row-desc" style="font-family:'JetBrains Mono',monospace;font-size:12px;">
              ${lab.no} / ${escapeHtml(t.no)} · ${t.code.split('\n').length} 行
            </div>
            <div class="detail-tags">
              ${t.tags.map(x => `<span class="tag">${escapeHtml(x)}</span>`).join('')}
            </div>
          </div>
          <button class="copy-btn" id="copyBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <span>复制代码</span>
          </button>
        </div>
        <div class="detail-code">
          <pre><code class="language-python">${escapeHtml(t.code)}</code></pre>
        </div>
      </div>
    `;
  }

  function bindDetailEvents() {
    const btn = document.getElementById('copyBtn');
    const lab = labs.find(l => l.id === currentLab);
    const code = lab.tasks[currentTask].code;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(code).then(() => {
        btn.classList.add('copied');
        btn.querySelector('span').textContent = '已复制';
        showToast('已复制到剪贴板');
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.querySelector('span').textContent = '复制代码';
        }, 1800);
      });
    });
  }

  /* ============ 视图切换 ============ */
  document.getElementById('viewList').addEventListener('click', () => {
    currentView = 'list';
    document.getElementById('viewList').classList.add('active');
    document.getElementById('viewGrid').classList.remove('active');
    if (currentTask === null) render();
  });
  document.getElementById('viewGrid').addEventListener('click', () => {
    currentView = 'grid';
    document.getElementById('viewGrid').classList.add('active');
    document.getElementById('viewList').classList.remove('active');
    if (currentTask === null) render();
  });

  /* ============ 主题切换 ============ */
  const themeToggle = document.getElementById('themeToggle');
  const iconDark = document.getElementById('iconDark');
  const iconLight = document.getElementById('iconLight');
  const hljsTheme = document.getElementById('hljs-theme');

  themeToggle.addEventListener('click', () => {
    const isLight = document.documentElement.dataset.theme === 'light';
    document.documentElement.dataset.theme = isLight ? 'dark' : 'light';
    iconDark.style.display = isLight ? 'none' : '';
    iconLight.style.display = isLight ? '' : 'none';
    hljsTheme.href = isLight
      ? 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css'
      : 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css';
    if (currentTask !== null) {
      setTimeout(() => {
        const code = document.querySelector('pre code');
        if (code) {
          code.removeAttribute('data-highlighted');
          hljs.highlightElement(code);
        }
      }, 50);
    }
  });

  /* ============ Toast ============ */
  const toast = document.getElementById('toast');
  let toastTimer;
  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 1800);
  }

  /* ============ 初始化 ============ */
  render();
</script>
